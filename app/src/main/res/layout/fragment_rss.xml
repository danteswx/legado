<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:attachToActivity="false"
        app:contentLayout="@layout/view_search"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/rss" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/ll_rss_source_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:id="@+id/ll_rss_source_select"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="2dp">

                    <TextView
                        android:id="@+id/tv_rss_source_select"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/primaryText"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="默认订阅源" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_rss_source_arrow"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/rss"
                        android:src="@drawable/ic_arrow_drop_down"
                        app:tint="@color/primaryText" />

                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_rss_source_search"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:contentDescription="@string/search"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_search"
                    android:tint="@color/primaryText"
                    android:visibility="gone" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_rss_source_star"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:contentDescription="@string/favorite"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_star"
                    android:tint="@color/primaryText" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_rss_source_login"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_discover_embedded_action"
                    android:contentDescription="@string/login"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_bottom_person"
                    android:tint="@color/primaryText" />

            </LinearLayout>

            <io.legado.app.ui.widget.RoundedTagBarView
                android:id="@+id/rv_rss_tags"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/fl_rss_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false">

                <io.legado.app.ui.widget.recycler.RecyclerViewAtPager2
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="1"
                    tools:listitem="@layout/item_rss" />

                <FrameLayout
                    android:id="@+id/rss_fragment_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/rss_web_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_empty_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="@string/rss_source_empty"
                    android:textColor="@color/secondaryText"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/pb_rss_loading"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
