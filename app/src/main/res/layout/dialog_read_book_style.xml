<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="390dp"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="10dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <View
        android:id="@+id/vw_drag_handle"
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        tools:background="#33000000" />

    <TextView
        android:id="@+id/tv_font_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_font"
        android:textColor="@color/primaryText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:id="@+id/font_scroll"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/font_row"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/font_option_source"
                android:layout_width="88dp"
                android:layout_height="72dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp">

                    <TextView
                        android:id="@+id/tv_font_source"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:singleLine="true"
                        android:text="@string/read_style_font_source"
                        android:textColor="@color/primaryText"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_font_source_check"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="end|bottom"
                        android:padding="5dp"
                        android:src="@drawable/ic_check"
                        android:visibility="gone"
                        app:tint="@color/white" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_font_source_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/read_style_default"
                    android:textColor="@color/primary"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/font_option_sans"
                android:layout_width="88dp"
                android:layout_height="72dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tv_font_sans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/read_style_font_sans"
                    android:textColor="@color/primaryText"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_font_sans_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-8dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="@color/white" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/font_option_art"
                android:layout_width="88dp"
                android:layout_height="72dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tv_font_art"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/read_style_font_art"
                    android:textColor="@color/primaryText"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_font_art_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-8dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="@color/white" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/font_option_kai"
                android:layout_width="88dp"
                android:layout_height="72dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tv_font_kai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/read_style_font_kai"
                    android:textColor="@color/primaryText"
                    android:textSize="18sp" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_font_kai_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-8dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="@color/white" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/font_option_custom"
                android:layout_width="88dp"
                android:layout_height="72dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tv_font_custom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/read_style_font_custom"
                    android:textColor="@color/primaryText"
                    android:textSize="18sp" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_font_custom_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-8dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone"
                    app:tint="@color/white" />

            </LinearLayout>

        </LinearLayout>

    </HorizontalScrollView>

    <View
        android:id="@+id/vw_divider_weight"
        android:layout_width="match_parent"
        android:layout_height="0.8dp"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tv_font_weight_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/read_style_font_weight"
        android:textColor="@color/primaryText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/ll_font_weight"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_weight_a_small"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="A"
            android:textColor="@color/primaryText"
            android:textSize="18sp" />

        <io.legado.app.lib.theme.view.ThemeSeekBar
            android:id="@+id/seek_font_weight"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/tv_weight_a_big"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="A"
            android:textColor="@color/primaryText"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_font_weight_value"
            android:layout_width="96dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical|end"
            android:singleLine="true"
            android:textColor="@color/primary"
            android:textSize="18sp" />

    </LinearLayout>

    <View
        android:id="@+id/vw_divider_size"
        android:layout_width="match_parent"
        android:layout_height="0.8dp" />

    <TextView
        android:id="@+id/tv_text_size_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/read_style_text_size"
        android:textColor="@color/primaryText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/ll_text_size"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_text_size_reduce"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="7dp"
            android:src="@drawable/ic_reduce"
            app:tint="@color/primaryText" />

        <io.legado.app.lib.theme.view.ThemeSeekBar
            android:id="@+id/seek_text_size"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:max="75" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_text_size_plus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="7dp"
            android:src="@drawable/ic_add"
            app:tint="@color/primaryText" />

        <TextView
            android:id="@+id/tv_text_size_value"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical|end"
            android:singleLine="true"
            android:textColor="@color/primary"
            android:textSize="27sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_tab_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="14dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/tab_font"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tab_font_icon"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/white"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tv_tab_font"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_font"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/vw_tab_divider_1"
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:id="@+id/tab_layout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_tab_layout"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="3dp"
                android:src="@drawable/ic_toc"
                app:tint="@color/primaryText" />

            <TextView
                android:id="@+id/tv_tab_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/read_style_layout"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/vw_tab_divider_2"
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:id="@+id/tab_theme"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_tab_theme"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="2dp"
                android:src="@drawable/ic_reader_palette"
                app:tint="@color/primaryText" />

            <TextView
                android:id="@+id/tv_tab_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/vw_tab_divider_3"
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:id="@+id/tab_page"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_tab_page"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="2dp"
                android:src="@drawable/ic_reader_page"
                app:tint="@color/primaryText" />

            <TextView
                android:id="@+id/tv_tab_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/read_style_page"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/vw_tab_divider_4"
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:id="@+id/tab_more"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_tab_more"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="2dp"
                android:src="@drawable/ic_more_horiz"
                app:tint="@color/primaryText" />

            <TextView
                android:id="@+id/tv_tab_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/read_style_more"
                android:textColor="@color/primaryText"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
