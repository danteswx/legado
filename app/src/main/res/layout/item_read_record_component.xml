<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="30dp"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/cb_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/primaryText"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/iv_drag"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:alpha="0.6"
            android:contentDescription="@string/read_record_drag_sort"
            android:src="@drawable/ic_arrange" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="40dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/secondaryText"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/lay_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/preview_a"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1" />

        <View
            android:id="@+id/preview_b"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1" />

        <View
            android:id="@+id/preview_c"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
